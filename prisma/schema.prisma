// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                      String                       @id @default(uuid())
  subject                 String                       @unique
  email                   String                       @unique
  name                    String
  status                  UserStatus                   @default(ACTIVE)
  credential              UserCredential?
  serviceMemberships      UserServiceMembership[]
  registrationInvitations UserRegistrationInvitation[] @relation("RegisteredUser")
}

enum UserStatus {
  PENDING
  ACTIVE
  DISABLED
}

model UserCredential {
  id           String @id @default(uuid())
  userId       String @unique
  passwordHash String
  user         User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Service {
  id                      String                       @id @default(uuid())
  clientId                String                       @unique
  name                    String
  type                    ServiceType                  @default(APPLICATION)
  maintainerAccount       MaintainerAccount?
  memberships             UserServiceMembership[]
  roles                   ServiceRole[]
  registrationInvitations UserRegistrationInvitation[]
}

enum ServiceType {
  APPLICATION
  LABORATORY
}

model MaintainerAccount {
  id           String   @id @default(uuid())
  serviceId    String   @unique
  subject      String   @unique
  email        String
  name         String
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  service      Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([serviceId, email])
}

model UserServiceMembership {
  userId    String
  serviceId String
  user      User                        @relation(fields: [userId], references: [id], onDelete: Cascade)
  service   Service                     @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  roles     UserServiceMembershipRole[]

  @@id([userId, serviceId])
}

model ServiceRole {
  id          String                      @id @default(uuid())
  serviceId   String
  name        String
  service     Service                     @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  memberships UserServiceMembershipRole[]

  @@unique([serviceId, name])
  @@unique([id, serviceId])
}

model UserServiceMembershipRole {
  userId        String
  serviceId     String
  serviceRoleId String
  membership    UserServiceMembership @relation(fields: [userId, serviceId], references: [userId, serviceId], onDelete: Cascade)
  serviceRole   ServiceRole           @relation(fields: [serviceRoleId, serviceId], references: [id, serviceId], onDelete: Cascade)

  @@id([userId, serviceId, serviceRoleId])
}

model UserRegistrationInvitation {
  id                String                           @id @default(uuid())
  code              String                           @unique
  serviceId         String
  status            UserRegistrationInvitationStatus @default(OPEN)
  createdBySubject  String?
  createdByClientId String?
  registeredUserId  String?                          @unique
  createdAt         DateTime                         @default(now())
  registeredAt      DateTime?
  approvedAt        DateTime?
  service           Service                          @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  registeredUser    User?                            @relation("RegisteredUser", fields: [registeredUserId], references: [id], onDelete: SetNull)

  @@index([serviceId, status])
}

enum UserRegistrationInvitationStatus {
  OPEN
  CLAIMED
  APPROVED
  REJECTED
}

model ApiRequestLog {
  id             String   @id @default(uuid())
  requestId      String?
  method         String
  path           String
  route          String?
  statusCode     Int?
  durationMs     Int?
  success        Boolean  @default(false)
  clientIp       String?
  userAgent      String?
  contentLength  Int?
  clientId       String?
  subject        String?
  tokenType      String?
  audiences      String[] @default([])
  scopes         String[] @default([])
  requestHeaders Json?
  requestQuery   Json?
  requestBody    Json?
  errorName      String?
  errorMessage   String?
  errorCode      String?
  metadata       Json?
  createdAt      DateTime @default(now())

  @@index([createdAt])
  @@index([requestId])
  @@index([clientId, createdAt])
  @@index([method, statusCode])
  @@index([path, statusCode])
  @@index([success, createdAt])
}
